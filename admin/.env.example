# ============================================================
# local-biz-ops admin — Environment Variables
# ============================================================
# Copy to .env.local and fill in real values. With NOTHING set, the kit runs
# in dev simulation: Turnstile is bypassed and emails are logged, not sent —
# so the v0.1 lead → CRM → follow-up → review path is fully demoable at $0.

# --- Site link-back (should match the marketing site's NEXT_PUBLIC_SITE_URL) ---
NEXT_PUBLIC_SITE_URL=https://yourdomain.ca

# --- Resend email (free tier: 100 emails/day) — same wiring as the site kit ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@yourdomain.ca
RESEND_TO_EMAIL=owner-inbox@gmail.com

# --- Cloudflare Turnstile (free) — protects the public intake form ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# --- Review destination for the review-request step ---
# Google Business Profile "write a review" deep link (replace the Place ID).
GOOGLE_REVIEW_URL=https://search.google.com/local/writereview?placeid=TODO_GBP_PLACE_ID

# --- Trusted server-to-server intake ---
# Shared secret the marketing site / n8n present as the X-Ops-Token header to
# POST /api/leads without a Turnstile token. Leave blank to require Turnstile.
OPS_INTAKE_TOKEN=
